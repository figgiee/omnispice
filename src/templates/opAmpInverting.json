{
  "id": "opamp-inverting",
  "name": "Inverting Op-Amp Amplifier",
  "description": "Classic inverting amplifier with gain -Rf/Rin, ±12V rails, and virtual-ground input bias.",
  "tags": ["opamp", "amplifier", "analog", "inverting"],
  "components": [
    {
      "tmpId": "u1",
      "type": "ideal_opamp",
      "value": "",
      "position": { "x": 0, "y": 0 },
      "rotation": 0,
      "portNames": ["non_inv", "inv", "output"]
    },
    {
      "tmpId": "rin",
      "type": "resistor",
      "value": "10k",
      "position": { "x": -140, "y": -20 },
      "rotation": 0,
      "portNames": ["pin1", "pin2"]
    },
    {
      "tmpId": "rf",
      "type": "resistor",
      "value": "100k",
      "position": { "x": 0, "y": -120 },
      "rotation": 0,
      "portNames": ["pin1", "pin2"]
    },
    {
      "tmpId": "vin",
      "type": "ac_voltage",
      "value": "0.1",
      "position": { "x": -260, "y": -20 },
      "rotation": 0,
      "portNames": ["positive", "negative"]
    },
    {
      "tmpId": "vpos",
      "type": "dc_voltage",
      "value": "12",
      "position": { "x": -60, "y": 160 },
      "rotation": 0,
      "portNames": ["positive", "negative"]
    },
    {
      "tmpId": "gnd",
      "type": "ground",
      "value": "",
      "position": { "x": -120, "y": 240 },
      "rotation": 0,
      "portNames": ["pin1"]
    }
  ],
  "wires": [
    { "tmpId": "w1", "from": { "comp": "vin", "port": "positive" }, "to": { "comp": "rin", "port": "pin1" } },
    { "tmpId": "w2", "from": { "comp": "rin", "port": "pin2" }, "to": { "comp": "u1", "port": "inv" } },
    { "tmpId": "w3", "from": { "comp": "u1", "port": "inv" }, "to": { "comp": "rf", "port": "pin1" } },
    { "tmpId": "w4", "from": { "comp": "rf", "port": "pin2" }, "to": { "comp": "u1", "port": "output" } },
    { "tmpId": "w5", "from": { "comp": "u1", "port": "non_inv" }, "to": { "comp": "gnd", "port": "pin1" } },
    { "tmpId": "w6", "from": { "comp": "vin", "port": "negative" }, "to": { "comp": "gnd", "port": "pin1" } },
    { "tmpId": "w7", "from": { "comp": "vpos", "port": "negative" }, "to": { "comp": "gnd", "port": "pin1" } }
  ]
}
