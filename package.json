    "@tanstack/react-query": "^5.97.0",
    "@xyflow/react": "^12.10.2",
    "cmdk": "^1.1.1",
    "dompurify": "^3.3.3",
    "elkjs": "^0.11.1",
    "html-to-image": "1.11.13",
    "html2canvas": "^1.4.1",
    "jspdf": "3.0.2",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^1.8.0",
    "marked": "^15.0.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "react-resizable-panels": "^4.9.0",
